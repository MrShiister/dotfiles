#!/bin/sh

packages="vim tmux"
{{ if not .devcontainer }}
packages="${packages} git zsh"
{{ end }}

{{ if eq .chezmoi.osRelease.id "ubuntu" "debian" }}
{{ .sudo }}apt update
{{ .sudo }}apt install -y ${packages}
{{ else if eq .chezmoi.osRelease.id "arch" }}
{{ .sudo }}pacman -Syu yay ${packages}
{{ else if eq .chezmoi.osRelease.id "alpine" }}
{{ .sudo }}apk add ${packages}
{{ end }}

if ! chsh -s $(which zsh) $USER; then 
    echo "Failed to change default shell to zsh."
fi