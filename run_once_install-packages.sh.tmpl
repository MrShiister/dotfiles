#!/bin/sh

packages="vim zsh"

# Get ZSH shell
{{ if eq .chezmoi.osRelease.id "ubuntu" "debian" }}
sudo apt update
sudo apt install -y ${packages}
{{ else if eq .chezmoi.osRelease.id "arch" }}
sudo pacman -Syu yay ${packages}
{{ else if eq .chezmoi.osRelease.id "alpine" }}
apk add ${packages} sudo curl git
{{ end }}

